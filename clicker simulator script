--Clicker Simulator --
local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()

local Players = game:GetService("Players")
local UIS = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer


local Window = Rayfield:CreateWindow({
	Name = "zerocaution on telegram",
	LoadingTitle = "larping",
	LoadingSubtitle = "by zerocaution"
})


local MainTab = Window:CreateTab("Main", 4483362458)
local FreeSeasonTab = Window:CreateTab("Free Rewards", 4483362458)
local WorldTab = Window:CreateTab("World", 4483362458)
local SpinTab = Window:CreateTab("Spin", 4483362458)
local UpgradeTab = Window:CreateTab("Upgrades", 4483362458)

local autoClick = false
local loopThread



MainTab:CreateToggle({
	Name = "Auto Clicker",
	CurrentValue = false,
	Callback = function(Value)
		autoClick = Value

		if autoClick and not loopThread then
			loopThread = task.spawn(function()
				while autoClick do
					ReplicatedStorage
						:WaitForChild("Game")
						:WaitForChild("Events")
						:WaitForChild("Click")
						:FireServer()

					task.wait(0.05)
				end
				loopThread = nil
			end)
		end
	end
})



for i = 1, 10 do
	FreeSeasonTab:CreateButton({
		Name = "Claim Tier " .. i,
		Callback = function()
			ReplicatedStorage
				:WaitForChild("Game")
				:WaitForChild("Events")
				:WaitForChild("Season")
				:FireServer("Claim", "Free", i)
		end
	})
end

